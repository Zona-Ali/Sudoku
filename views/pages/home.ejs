<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SUDOKU</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Fontdiner+Swanky&family=Knewave&family=Mogra&family=Solitreo&family=Special+Elite&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body style="background-color: #93a4ff;">
    <div id="box">
        <div id="boxhead" style="padding: 1rem 1rem 0.5rem 1rem;">

            <% if(!currentUser){ %>
                <a href="/signup"> <i class="fa-solid fa-user-plus"></i> &nbsp;<b>SignUp</b></a> &nbsp; &nbsp;
                <a href="/login"> <i class="fa-solid fa-right-to-bracket"></i> &nbsp;<b>LogIn</b></a>
                <% } %>
                    <% if(currentUser){ %>
                        <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> &nbsp;<b>LogOut</b></a>
                        <% } %>
        </div>

        <hr>

        <h1>SUDOKU</h1>

        <a href="/sudokuPlay">
            <div class="fun-btn">PLAY SUDOKU</div>
        </a>
        <br> <br>
        <a href="/sudokuSolver">
            <div class="fun-btn">SUDOKU SOLVER</div>
        </a>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>